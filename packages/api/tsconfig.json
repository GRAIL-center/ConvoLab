{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": [
      "ES2022"
    ],
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "allowJs": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": [
      "node"
    ],

    "paths": {
      "@workspace/*": [
        "../*"
      ],
      "@workspace/database": [
        "../database/src"
      ]
    }
  },
  "include": [
    "src/**/*",
    "../database/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}